# SATRIA Core
APP_ENV=development
SATRIA_DEMO_MODE=false
SATRIA_SECRET_KEY=change-me

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
BACKEND_PUBLIC_PORT=8090
DATABASE_URL=postgresql+psycopg://satria:satria_password@satria-db:5432/satria
CELERY_BROKER_URL=redis://satria-redis:6379/0
CELERY_RESULT_BACKEND=redis://satria-redis:6379/1
REPORT_DIR=/data/reports

# PostgreSQL
POSTGRES_DB=satria
POSTGRES_USER=satria
POSTGRES_PASSWORD=satria_password

# DFIR-IRIS connector; leave blank for stub mode
IRIS_URL=
IRIS_API_KEY=
IRIS_VERIFY_SSL=false
IRIS_NOTE_DIRECTORY=SATRIA Timeline
IRIS_EVIDENCE_FOLDER=SATRIA Evidence
SOC_L1_USER=cakgup1
SOC_L2_USER=cakgup2
SOC_L3_USER=cakgup3

# Greenbone/OpenVAS connector; leave blank for stub mode
GREENBONE_HOST=
GREENBONE_USERNAME=
GREENBONE_PASSWORD=
GREENBONE_VERIFY_SSL=false
ZAP_CONTAINER_NAME=satria-zap

# Scanner safety
ALLOW_ACTIVE_SCAN=false
SCAN_TARGET_ALLOWLIST=localhost,127.0.0.1,host.docker.internal,192.168.56.0/24,nginx:latest,python:3.12-slim,https://example.com,http://example.com,redteam-console
